#!/bin/bash
# 守門員：擋住任何把 Service Worker 加回來的 commit。
# 背景：SW 快取更新問題從 v206 bump 到 v301 共 95 次都治不好，
# 2026-07-07 定案移除 SW、改純 manifest PWA，新鮮度由 _headers no-cache 保證。
# sw.js 現在是 kill switch（解除舊裝置註冊），永久保留、不准改回快取邏輯。

set -e

fail() {
  echo "❌ pre-commit 擋下：$1"
  echo "   此專案已定案移除 Service Worker（見 README「PWA 快取策略」）。"
  echo "   不准重新註冊 SW、不准在 sw.js 加快取邏輯、不准 bump 版本參數。"
  exit 1
}

# 1. HTML 不准出現 serviceWorker.register
if git diff --cached -U0 -- '*.html' | grep -E '^\+.*serviceWorker\.register' >/dev/null; then
  fail "偵測到 serviceWorker.register 被加回 HTML"
fi

# 2. sw.js 不准出現 fetch handler 或 caches.open（kill switch 只清不存）
if git diff --cached --name-only | grep -qx 'sw.js'; then
  if git show :sw.js | grep -E "addEventListener\('fetch'|caches\.open" >/dev/null; then
    fail "sw.js 被加回快取邏輯（fetch handler / caches.open）"
  fi
fi

# 3. 不准刪 _headers（唯一的新鮮度機制）
if git diff --cached --name-only --diff-filter=D | grep -qx '_headers'; then
  fail "_headers 被刪除（它是唯一保證使用者拿到最新版的機制）"
fi

exit 0
